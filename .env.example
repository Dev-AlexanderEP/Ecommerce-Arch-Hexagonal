# Copia a .env en el VPS y rellena con valores reales. NO commitear .env.
# Formato .NET: Seccion__Clave sobreescribe appsettings.json

ASPNETCORE_ENVIRONMENT=Production

# Password de Postgres (lo usa el contenedor postgres Y la cadena de conexión)
POSTGRES_PASSWORD=cambia_este_password

# Conexiones (host = nombre del servicio en docker, no localhost)
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=mixandmatch;Username=postgres;Password=cambia_este_password
ConnectionStrings__Redis=redis:6379

# Genera con: openssl rand -base64 48
Jwt__Key=cambia_por_clave_aleatoria_min_32_chars

# Gmail app password
Smtp__Password=tu_app_password_gmail

# Dashboard de Hangfire (basic auth en producción)
Hangfire__Login=admin
Hangfire__Password=cambia_este_password

# PayPal (rellenar al implementar webhooks)
PayPal__ClientId=
PayPal__Secret=
PayPal__WebhookId=
PayPal__Mode=live
